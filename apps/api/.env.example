# Reprompt API — environment variables
# Copy this file to .env and fill in real values before running the server.
# .env is gitignored; never commit real secrets.
#
# Quick start: run `bash scripts/setup.sh` from the repo root — it generates
# REPROMPT_SETTINGS_ENCRYPTION_KEY for you and writes it into apps/api/.env.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite (default — no extra setup needed for local dev or tests):
# DATABASE_URL=sqlite:///./test.db

# Postgres (optional — see docs/DEVELOPMENT.md "Running against Postgres"):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/reprompt

# ---------------------------------------------------------------------------
# Encryption key for BYOK API key storage
# ---------------------------------------------------------------------------

# Required before the /settings/api-keys endpoints will work.
# Generate a real key with:
#   cd apps/api && uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# scripts/setup.sh does this for you automatically.
REPROMPT_SETTINGS_ENCRYPTION_KEY=replace-with-output-of-fernet-generate-key

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# HMAC signing secret for session tokens. Any long random string works.
# If unset, the server falls back to an insecure hardcoded default and logs
# a warning — fine for local dev, must be set before any real deployment.
# REPROMPT_SESSION_SECRET=replace-with-a-long-random-secret

# Return the magic-link URL directly in the /auth/request-link API response
# instead of sending email (no email provider is wired up yet). Keep true
# for local dev; set to false once a real email provider is configured.
REPROMPT_DEV_MAGIC_LINKS=true

# Base URL the magic link points back to. Default is the Vite dev server.
# REPROMPT_WEB_BASE_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Optimizer
# ---------------------------------------------------------------------------

# Which prompt-optimization strategy to use when a migration is started.
# "simple"  — one mutation call then a param/format sweep (default, cheaper).
# "prism"   — multi-round mutate → cheap-score → critique → refine → sweep.
# See DEV_TRACKER.md "Why two strategies, and why the name Prism" for detail.
OPTIMIZER_STRATEGY=simple

# ---------------------------------------------------------------------------
# System harness models — rubric generation / judge / mutator
# ---------------------------------------------------------------------------
#
# Reprompt's OWN infrastructure calls (reverse-engineering a rubric,
# scoring a candidate against it, proposing a mutated prompt) - NOT a
# workspace's own target models under test. Unset by default: each purpose
# auto-selects from whatever the workspace has configured (see
# reprompt_core.llm.model_select.select_model / DEV_TRACKER.md's "System
# model config" entry). Set any of these to *pin* that purpose to one
# exact model instead - this is a HARD requirement, not a soft default:
# every workspace using this deployment then needs its own BYOK key for
# that model's provider, or the call fails with a clear error rather than
# silently falling back. Same var works for all three purposes
# individually - set one, some, or all.
#
# Current default (commented out below): NVIDIA NIM's free tier,
# DeepSeek V4 Flash - a 1M-token-context model, more than enough for even
# a large rubric-generation context, at zero cost while still in
# development. Requires an NVIDIA_NIM_API_KEY added via Settings for
# every workspace that needs rubric generation / a migration to run.
# REPROMPT_RUBRIC_MODEL=nvidia_nim/deepseek-ai/deepseek-v4-flash
# REPROMPT_JUDGE_MODEL=nvidia_nim/deepseek-ai/deepseek-v4-flash
# REPROMPT_MUTATOR_MODEL=nvidia_nim/deepseek-ai/deepseek-v4-flash
#
# Alternatives, ready to swap in later (same three vars, pick one set):
#   Anthropic:  REPROMPT_JUDGE_MODEL=claude-sonnet-4-5
#   OpenAI:     REPROMPT_JUDGE_MODEL=gpt-4o
#   Gemini:     REPROMPT_JUDGE_MODEL=gemini/gemini-2.0-flash
